{
  "id": "commerce.plugin",
  "label": "Plugin (interceptor)",
  "class": "B",
  "pack": "commerce",
  "applicability": "on-prem",
  "detect": "bin/magento",
  "fields": [
    { "id": "vendor", "label": "Vendor", "type": "text", "validate": "identifier", "default": "Vendor" },
    { "id": "module", "label": "Module", "type": "text", "validate": "identifier", "default": "Module" },
    { "id": "pluginName", "label": "Plugin class", "type": "text", "validate": "identifier", "default": "MyPlugin" },
    { "id": "targetClass", "label": "Target class/interface (FQN)", "type": "text", "validate": "non-empty", "default": "Magento\\Catalog\\Api\\ProductRepositoryInterface" }
  ],
  "files": [
    { "path": "app/code/${vendor}/${module}/Plugin/${pluginName}.php", "template": "plugin.php" },
    { "path": "app/code/${vendor}/${module}/etc/di.xml", "template": "di.xml", "xmlMerge": { "parent": "config", "idAttr": "name", "rootTag": "config" } }
  ],
  "postNote": "Registered in etc/di.xml automatically (a <type name=\"${targetClass}\"> with your <plugin>). NOTE: for MULTIPLE plugins on the SAME target class, add the extra <plugin> under the existing <type> by hand (the merge dedups by target name). sortOrder when conflicting (commerce/plugin-sort-order)."
}
