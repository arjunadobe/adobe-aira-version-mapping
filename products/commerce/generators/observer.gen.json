{
  "id": "commerce.observer",
  "label": "Event observer",
  "class": "B",
  "pack": "commerce",
  "applicability": "on-prem",
  "detect": "bin/magento",
  "fields": [
    { "id": "vendor", "label": "Vendor", "type": "text", "validate": "identifier", "default": "Vendor" },
    { "id": "module", "label": "Module", "type": "text", "validate": "identifier", "default": "Module" },
    { "id": "observerName", "label": "Observer class", "type": "text", "validate": "identifier", "default": "MyObserver" },
    { "id": "event", "label": "Event name", "type": "text", "default": "catalog_product_save_after" }
  ],
  "files": [
    { "path": "app/code/${vendor}/${module}/Observer/${observerName}.php", "template": "observer.php" },
    { "path": "app/code/${vendor}/${module}/etc/events.xml", "template": "events.xml", "xmlMerge": { "parent": "config", "idAttr": "name", "rootTag": "config" } }
  ],
  "postNote": "Registered in etc/events.xml automatically (an <event name=\"${event}\"> with your <observer>). NOTE: for MULTIPLE observers on the SAME event, add the extra <observer> under the existing <event> by hand (the merge dedups by event name). Use etc/<area>/events.xml for area-specific events."
}
